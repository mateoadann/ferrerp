# Flask
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# Seguridad
SECRET_KEY=cambiar-esta-clave-en-produccion-usar-algo-seguro

# Clave de encriptación para certificados ARCA (Fernet AES-128-CBC)
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# Base de datos
# SQLite (para desarrollo simple, no requiere instalacion):
# DATABASE_URL=sqlite:///ferrerp_dev.db

# PostgreSQL (para produccion):
DATABASE_URL=postgresql://usuario:password@localhost:5432/ferrerp

# Configuracion de la aplicacion
APP_NAME=FerrERP
ITEMS_PER_PAGE=20
